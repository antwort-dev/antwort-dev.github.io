<script>
// Theme synchronization with main Astro site.
// Both sites share localStorage.theme on the same origin (antwort-dev.github.io).
// Default to dark if no preference is stored (main site defaults to dark).
(function() {
  var theme = localStorage.getItem('theme');
  if (!theme) {
    // No stored preference: check system preference, default to dark
    theme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
  }
  if (theme === 'dark') {
    document.documentElement.classList.add('dark');
  } else {
    document.documentElement.classList.remove('dark');
  }
})();
</script>
